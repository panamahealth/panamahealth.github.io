---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Investor Outreach — PanamaHealth',
  description:
    'Pre-seed investor outreach for PanamaHealth — the edge-native federated intelligence OS for healthcare.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Investor Outreach"
    title="Building the OS the future of healthcare runs on"
    subtitle="Pre-seed round open. Talk directly to the founders."
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Request the Deck',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">Ready to back the OS of healthcare AI?</Fragment>

    <Fragment slot="subtitle"> We respond to qualified investor inquiries within 1–2 business days. </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-cyan-blue opacity-10"></div>
    </Fragment>
  </CallToAction>
</Layout>
