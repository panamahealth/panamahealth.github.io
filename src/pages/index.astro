---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'PanamaHealth — Edge-Native Federated Intelligence OS for Healthcare',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->

  <Hero
    tagline="Edge-Native Federated Intelligence OS for Healthcare"
    actions={[
      {
        variant: 'primary',
        text: 'Request a Demo',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Connecting oceans of <br /><span class="text-primary">intelligence</span>, not data
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-cyan-blue opacity-10"></div>
    </Fragment>
  </Hero>

  <!-- The Vision ******************* -->

  <Features2
    id="vision"
    tagline="The Vision"
    title="The OS the future of healthcare runs on"
    subtitle="Imagine every hospital, every lab, every medical device on the planet contributing to one continuously improving intelligence — privately, legally, automatically. That world is coming."
    columns={3}
    items={[
      {
        title: 'Layer 1 — The OS',
        icon: 'tabler:server-2',
      },
      {
        title: 'Layer 2 — Agentic Tools',
        icon: 'tabler:robot',
      },
      {
        title: 'Layer 3 — The Global Network',
        icon: 'tabler:world',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- The Product ******************* -->

  <Features2
    id="product"
    tagline="The Product"
    title="What Panama Health does"
    subtitle="Nothing gets replaced. Everything gets smarter."
    columns={2}
    items={[
      {
        title: 'Federated learning core',
        icon: 'tabler:cpu',
      },
      {
        title: 'Agentic AI orchestration',
        icon: 'tabler:robot',
      },
      {
        title: 'Security by design',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Works with existing systems',
        icon: 'tabler:plug-connected',
      },
    ]}
  />

  <Features
    columns={4}
    items={[
      { title: 'HIPAA native', icon: 'tabler:shield-check' },
      { title: 'HL7 FHIR', icon: 'tabler:file-text' },
      { title: 'On-prem or hybrid', icon: 'tabler:building' },
      { title: 'Device agnostic', icon: 'tabler:devices' },
    ]}
  />

  <!-- Call to Action / Ask ******************* -->

  <CallToAction
    id="pilot"
    actions={[
      {
        variant: 'primary',
        text: 'Request Pilot Access',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">Every hospital. Every lab. Every pharma. Built on Panama Health.</Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">Raising:</span> Pre-seed round — $350K–$500K
      <br class="hidden md:inline" />
      <br class="hidden md:inline" />
      <span class="font-semibold">Use of funds:</span> Accelerate agentic tool delivery to production and expand network
      contracts — scaling the client base and the platform simultaneously.
      <br class="hidden md:inline" />
      <br class="hidden md:inline" />
      <span class="font-semibold">Why us:</span> Healthcare AI operator + federated systems PhD + ARPA-H government procurement
      advisor.
      <br class="hidden md:inline" />
      <br class="hidden md:inline" />
      Reach us at
      <a href="mailto:info@panamahealth.ai" class="text-primary hover:underline">info@panamahealth.ai</a>
      &nbsp;·&nbsp;
      <a href="https://panamahealth.ai" class="text-primary hover:underline">panamahealth.ai</a>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-cyan-blue opacity-10"></div>
    </Fragment>
  </CallToAction>
</Layout>
