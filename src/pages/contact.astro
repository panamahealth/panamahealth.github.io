---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact PanamaHealth — Request a Demo',
  description:
    'Get in touch with PanamaHealth to request a demo of the edge-native federated intelligence OS for healthcare, or to discuss a pilot, partnership, or investment.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Get in Touch" title="Request a Demo" />

  <ContactUs
    id="form"
    title="Ready to transform healthcare AI?"
    subtitle="Whether you're a hospital, payer, pharma, CDMO, or investor — talk to us. The AI travels to the data. The data never moves. Your data stays with you. Zero compliance risk."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name *',
        placeholder: 'John Doe',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email *',
        placeholder: 'john@hospital.com',
      },
      {
        type: 'text',
        name: 'organization',
        label: 'Organization *',
        placeholder: 'Memorial Hospital',
      },
      {
        type: 'text',
        name: 'role',
        label: 'Your Role',
        placeholder: 'CTO, Head of AI, Research Director',
      },
    ]}
    textarea={{
      label: 'Tell us about your use case',
      name: 'message',
      placeholder: 'What healthcare AI challenge are you trying to solve? What data do you have available?',
      rows: 6,
    }}
    button="Request Demo"
    disclaimer={{
      label:
        'By submitting this form, you acknowledge and agree to the collection of your information for the purpose of evaluating your inquiry.',
    }}
    description="We typically respond within 1–2 business days to qualified inquiries."
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="How can we help you?"
    items={[
      {
        title: 'Pilot / Demo',
        description:
          'Hospital networks, payers, pharma, or CDMOs — request a demo of the federated OS and discuss a Phase 1 pilot with claims, RCM, or pharmacovigilance workflows.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Technical Questions',
        description:
          'Curious about edge-native training, Krum/Trimmed Mean aggregation, cryptographic provenance, or how we slot under your existing HIPAA + HL7 FHIR stack? Our team is here.',
        icon: 'tabler:help-circle',
      },
      {
        title: 'Partnership & Investment',
        description:
          'Pre-seed round open — $350K–$500K. Strategic partners welcome across regulatory, clinical, pharma, and enterprise health systems.',
        icon: 'tabler:users',
      },
      {
        title: 'Email',
        description: 'info@panamahealth.ai',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
